# 服务端口；QDH_PORT 优先，其次 PORT，默认 3000
QDH_PORT=3000

# 默认使用 Ollama，本地 Ollama 进程优先调用 Cloud 托管模型。启动前请先运行：ollama serve
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
# 默认不填 OLLAMA_MODEL 时会优先使用 OLLAMA_CLOUD_MODELS 的第一个候选。
# 如需强制指定本地模型，可取消下一行注释并改成你已 pull 的模型。
# OLLAMA_MODEL=qwen2.5:7b
OLLAMA_PREFER_CLOUD=true
OLLAMA_CLOUD_MODELS=gpt-oss:120b-cloud,gpt-oss:20b-cloud,qwen3-coder:480b-cloud,glm-4.7:cloud,minimax-m2.1:cloud,deepseek-v3.1:671b-cloud
LLM_TIMEOUT_SECONDS=120

# 可选：OpenAI-compatible 外部 API
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=https://api.example.com/v1
# LLM_API_KEY=your-api-key
# LLM_MODEL=qwen-max

# 静态资源目录；相对路径基于仓库根目录
STATIC_DIR=static

# ASR/TTS 由浏览器 Web Speech APIs 提供；后端不加载语音模型。

# 服务端口；QDH_PORT 优先，其次 PORT，默认 3000
QDH_PORT=3000

# 默认使用本地 Ollama。启动前请先运行：ollama serve
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
LLM_TIMEOUT_SECONDS=120

# 可选：OpenAI-compatible 外部 API
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=https://api.example.com/v1
# LLM_API_KEY=your-api-key
# LLM_MODEL=qwen-max

# 静态资源和模型目录；相对路径基于仓库根目录
STATIC_DIR=static
MODELS_DIR=models

# 第一阶段 ASR/TTS 仍是兼容实现
ASR_PROVIDER=stub
TTS_PROVIDER=silence
